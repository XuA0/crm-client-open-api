example {
  name: prop_trading
  
  request: {
    url: {{BASE_URL}}/private/v1/requests/search
    method: POST
    mode: json
    body:json: {
      {
          "skip": 0,
          "limit": 10,
          "orders": {},
          "type": "prop_trading",
          "searches": [
              {
                  "field": "id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "name",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "email",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "referrer_id",
                  "value": {
                      "user_id": [
                          "yf8svf7z"
                      ],
                      "type": "all", // "all"｜ "upline" ｜ "customer"
                      "max_depth": 1, // (only type === "customer")
                      "start_depth": 1 // 0 | 1 (only type === "customer")
                  },
                  "opt": "EQ"
              },
              {
                  "field": "package_id",
                  "value": "h7evf587",
                  "opt": "EQ"
              },
              {
                  "field": "status",
                  "value": [
                      "pending",
                      "approved",
                      "rejected",
                      "cancelled"
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "created_at",
