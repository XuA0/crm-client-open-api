example {
  name: withdrawal
  
  request: {
    url: {{BASE_URL}}/private/v1/requests/search
    method: POST
    mode: json
    body:json: {
      {
          "skip": 0,
          "limit": 10,
          "orders": {},
          "type": "withdrawal",
          "searches": [
              {
                  "field": "status",
                  "value": [
                      "pending",
                      "approved",
                      "rejected",
                      "cancelled"
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "trading_platform",
                  "value": [
                      "bigc8liz"
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "trading_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "created_at",
                  "value": {
                      "start": "2026-02-01 16:00:00",
                      "end": "2026-02-02 15:59:59"
                  },
                  "opt": "EQ"
