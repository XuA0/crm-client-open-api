meta {
  name: PKCE Get Token
  type: http
  seq: 8
}

post {
  url: {{BASE_URL}}/oauth/token
  body: json
  auth: inherit
}

body:json {
  {
      "grant_type": "authorization_code",
      "code": "",
      "code_verifier": ""
  }
}

settings {
