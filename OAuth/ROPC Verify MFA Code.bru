meta {
  name: ROPC Verify MFA Code
  type: http
  seq: 5
}

post {
  url: {{BASE_URL}}/oauth/mfa/verify
  body: json
  auth: inherit
}

body:json {
  {
      "mfa_token": "",
      "otp_code": ""
  }
}

script:post-response {
  if (res.getStatus() === 200) {
      const jsonData = res.getBody();
      
      // Safely extract tokens
      const accessToken = jsonData.access_token;
      const refreshToken = jsonData.refresh_token;
  
      // Validate existence before setting
      if (accessToken) {
          bru.setVar("AUTH_TOKEN", accessToken);
          console.log("✅ AUTH_TOKEN updated in collection variables.");
      } else {
          console.warn("⚠️ No access_token found in response.");
      }
  
      if (refreshToken) {
          bru.setVar("REFRESH_TOKEN", refreshToken);
          console.log("✅ REFRESH_TOKEN updated in collection variables.");
      } else {
          console.warn("⚠️ No refresh_token found in response.");
      }
  
  } else {
      console.error(`❌ Token request failed with status: ${res.getStatus()}`);
  }
}

settings {
  encodeUrl: true
}

