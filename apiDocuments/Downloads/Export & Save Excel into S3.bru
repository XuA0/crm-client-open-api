                  "type": "number"
              },
              {
                  "key": "netCredit", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "Net Credit",
                  "type": "number"
              },
              {
                  "key": "rebateTotal", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "Rebate Total",
                  "type": "number"
              },
              {
                  "key": "netProfit", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "Net Profit/Loss"
              },
              {
                  "key": "8983knu6", // （MT4 Symbol）Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "test group",
                  "type": "number"
              }
          ],
          "skip": 0,
          "limit": 10,
          "connection_id": "bigc8liz",
          "searches": [],
          "last": false,
          "start": "2026-01-29 00:00:00",
