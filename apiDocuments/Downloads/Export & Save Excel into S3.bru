meta {
  name: Export & Save Excel into S3
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/private/api/v1/file/export/excel/s3
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "scene": "TRADING_COMPETITION_PRIZE",
    "downloadType": "BONUS",
    "sync": true,
    "searches": [
      {
        "field": "string",
        "opt": "GTE",
        "value": {}
      },
      {
        "field": "string",
        "opt": "GT",
        "value": {}
      }
    ],
    "range": [
      {
        "field": "string",
        "opt": "NOT_BETWEEN",
        "value": {}
      },
      {
        "field": "string",
        "opt": "LT",
        "value": {}
      }
    ],
    "orders": {},
    "start": "string",
    "end": "string",
    "from": "string",
    "to": "string",
    "key": "string",
    "timeZone": "string",
    "lang": "string",
    "fieldMap": [
      {
        "key": "string",
        "value": "string",
        "type": "string",
        "format": "string"
      },
      {
        "key": "string",
        "value": "string",
        "type": "string",
        "format": "string"
      }
    ],
    "skip": 5874,
    "limit": 4352,
    "type": "string",
    "trader": "string",
    "currency": "string",
    "ruleId": "string",
    "connection_id": "string",
    "trading_platform": "string",
    "trading_id": "string",
    "order_id": "string",
    "batch_id": "string",
    "batch_type": "string",
    "mine": false,
    "platform": "string",
    "last": false,
    "is_active": false,
    "search_type": "string",
    "competition_id": "string",
    "capital_type": "string",
    "prop_trading_id": "string",
    "package_id": "string",
    "prop_trading": false,
    "mode": "string"
  }
}

settings {
  encodeUrl: true
}

example {
  name: MT4 Account Capital(Downline)
  
  request: {
    url: {{BASE_URL}}/private/api/v1/file/export/excel/s3
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
          "scene": "TRADE_CAPITAL_MT4",
          "downloadType": "REFERRALS",
          "timeZone": "+08:00",
          "fieldMap": [
              {
                  "key": "order_id",
                  "value": "Order ID"
              },
              {
                  "key": "trading_id",
                  "value": "Trading Account"
              },
              {
                  "key": "user_id",
                  "value": "User ID"
              },
              {
                  "key": "name",
                  "value": "Name"
              },
              {
                  "key": "email",
                  "value": "Email"
              },
              {
                  "key": "reportsAccountsCapitalTier",
                  "value": "Tier"
              },
              {
                  "key": "referrer_id",
                  "value": "Referrer"
              },
              {
                  "key": "type",
                  "value": "Type"
              },
              {
                  "key": "currency",
                  "value": "Currency"
              },
              {
                  "key": "amount",
                  "value": "Amount"
              },
              {
                  "key": "open_time",
                  "value": "Transaction Time",
                  "format": "yyyy-MM-dd HH:mm:ss"
              },
              {
                  "key": "comment",
                  "value": "Comment"
              }
          ],
          "skip": 0,
          "limit": 10,
          "searches": [],
          "orders": {},
          "connection_id": "bigc8liz",
          "range": [
              {
                  "field": "open_time",
                  "opt": "EQ",
                  "value": {
                      "start": "2026-01-23 00:00:00",
                      "end": "2026-01-30 23:59:59"
                  }
              }
          ],
          "last": false
      }
    }
  }
  
  response: {
    status: {
      code: OK
      text: 200
    }
  
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}

