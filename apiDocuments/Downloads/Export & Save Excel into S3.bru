    url: {{BASE_URL}}/private/api/v1/file/export/excel/s3
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
          "scene": "CUSTOMER_REPORTS_TRANSACTIONS",
          "downloadType": "USER_REPORT",
          "timeZone": "+08:00",
          "fieldMap": [
              {
                  "key": "id",
                  "value": "Transaction ID"
              },
              {
                  "key": "type",
                  "value": "Type"
              },
              {
                  "key": "account",
                  "value": "Account"
              },
              {
                  "key": "currency",
                  "value": "Currency"
              },
              {
                  "key": "amount",
                  "value": "Amount"
              },
              {
                  "key": "method",
                  "value": "Payment/Withdrawal Method"
              },
              {
                  "key": "payment_currency",
                  "value": "Payment/Withdrawal Currency"
              },
              {
                  "key": "payment_total",
                  "value": "Payment/Withdrawal Amount"
              },
              {
                  "key": "timestamp",
                  "value": "Time"
              },
              {
                  "key": "comment",
                  "value": "Comment"
              }
          ],
          "skip": 0,
          "limit": 10,
          "orders": {},
          "range": [
              {
                  "field": "timestamp",
                  "opt": "EQ",
                  "value": {
                      "start": "2026-01-22 16:00:00",
                      "end": "2026-01-30 15:59:59"
                  }
              }
          ],
          "searches": [],
          "mine": true
      }
    }
  }
  
  response: {
    body: {
      type: text
      content: '''
  
      '''
    }
  }
}
