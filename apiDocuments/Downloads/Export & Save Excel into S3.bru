                  "value": "Withdraw"
              },
              {
                  "key": "deposit",
                  "value": "Deposit"
              },
              {
                  "key": "commission",
                  "value": "Commission"
              },
              {
                  "key": "swaps",
                  "value": "Swaps"
              },
              {
                  "key": "profit",
                  "value": "Profit/Loss"
              },
              {
                  "key": "orderNum",
                  "value": "Total Number Of Orders"
              },
              {
                  "key": "openVolume",
                  "value": "Open Volume"
              },
              {
                  "key": "closeVolume",
                  "value": "Close Volume"
              },
              {
                  "key": "firstDepositTime",
                  "value": "Time Of First Deposit",
                  "format": "yyyy-MM-dd HH:mm:ss"
              },
              {
                  "key": "firstOpenTime",
                  "value": "Created Time",
                  "format": "yyyy-MM-dd HH:mm:ss"
              },
              {
                  "key": "firstTotal",
                  "value": "Initial Fund"
              },
              {
                  "key": "endTotal",
                  "value": "Final Fund"
              },
              {
                  "key": "firstEquity", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "First Equity",
                  "type": "number"
              },
              {
                  "key": "endEquity", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "End Equity",
                  "type": "number"
              },
              {
                  "key": "netEquity", // Available only when the MT4 Account Report External app is installed from the Marketplace.
                  "value": "Net Equity",
                  "type": "number"
