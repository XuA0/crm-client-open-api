meta {
  name: Get Referral Module Config
  type: http
  seq: 1
}

get {
  url: {{BASE_URL}}/private/v2/referrals/settings
  body: none
  auth: bearer
}

auth:bearer {
  token: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
}

