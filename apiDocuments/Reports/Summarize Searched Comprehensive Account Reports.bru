                "order_sum": 0,
                "close_sum": 0,
                "open_sum": 0,
                "first_sum": 300000102508.4,
                "end_sum": 300000102508.4,
                "first_equity_sum": 300000102508.4,
                "end_equity_sum": 300000102508.4,
                "net_deposit_sum": 0,
                "net_equity_sum": 0,
                "net_profit_sum": 0,
                "currency": "USD"
            },
            {
                "_id": "EUR",
