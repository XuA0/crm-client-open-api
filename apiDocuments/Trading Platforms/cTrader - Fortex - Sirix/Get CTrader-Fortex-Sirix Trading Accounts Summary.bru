          "connection_id": "xi3u7ek5",
          "orders": {},
          "searches": []
      }
    }
  }
  
  response: {
    status: {
      code: OK
      text: 200
    }
  
    body: {
      type: text
      content: '''
        {
            "statistics": [
                {
                    "sum_currency": "EUR",
