example {
  name: 200 Fortex Trade History
  
  request: {
    url: {{BASE_URL}}/private/v1/trade/trades/search
    method: POST
    mode: json
    body:json: {
      {
          "skip": 0,
          "limit": 10,
          "type": "trade history",
          "connection_id": "74mcgsjx",
          "orders": {},
          "searches": [
              {
                  "field": "name",
                  "value": "user",
                  "opt": "EQ"
              },
              {
                  "field": "order_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "position",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "trading_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "action",
                  "value": [
                      "0", // Buy
                      "3", // Sell Limit
                      "1", // Sell
                      "4", // Buy Stop
                      "2", // Buy Limit
                      "5" // Sell Stop
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "symbol",
                  "value": [
                      "AAPL",
                      "AUD/CHF",
                      "AUD/NZD"
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "volume",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "price",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "entry",
                  "value": [
                      "0", // In
                      "3", // CloseBy
                      "1", // Out
                      "2" // Reversal
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "trading_fee",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "swaps",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "profit",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "comment",
                  "value": {
                      "type": "like", // "startWith" ｜ "like"
                      "content": "123"
                  },
                  "opt": "EQ"
              },
              {
                  "field": "user_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "referrer_id",
                  "value": {
                      "user_id": [
                          "lo0i7w3o"
                      ],
                      "type": "all", // "all"｜ "upline" ｜ "customer"
                      "max_depth": 1, // (only type === "customer")
                      "start_depth": 1 // 0 | 1 (only type === "customer")
                  },
                  "opt": "EQ"
              },
              {
                  "field": "reports_trade_history_tier",
                  "value": {
                      "rank_id": "rd3ktdmy",
                      "tiers": [1, 2, 3]
                  },
                  "opt": "EQ"
              }
          ],
          "range": [
              {
                  "field": "time",
                  "opt": "EQ",
                  "value": {
                      "start": "2026-01-21 00:00:00",
                      "end": "2026-01-28 23:59:59"
                  }
              }
          ],
          "last": false,
          "key": "" // Order ID
      }
    }
  }
  
  response: {
    body: {
      type: text
      content: '''
        {
            "trades": [
                {
                    "order_id": 499531,
                    "trading_id": "Q001",
                    "action": 1,
                    "entry": 1,
                    "symbol": "GBP/CHF",
                    "volume": "0.5000",
                    "stop_loss": 0,
                    "take_profit": 0,
                    "time": "2025-11-13T02:29:04.000Z",
                    "price": 1.04784,
                    "trading_fee": -1.31,
