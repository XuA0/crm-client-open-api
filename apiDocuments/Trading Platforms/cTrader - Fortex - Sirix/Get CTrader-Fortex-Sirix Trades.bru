meta {
  name: Get CTrader/Fortex/Sirix Trades
  type: http
  seq: 15
}

post {
  url: {{BASE_URL}}/private/v1/trade/trades/search
  body: json
  auth: bearer
}

auth:bearer {
  token: {{AUTH_TOKEN}}
}

body:json {
  {
    "connection_id": "",
    "key": "",
    "searches": [
      {
        "field": "",
        "opt": "",
        "value": ""
      }
    ],
    "orders": {},
    "skip": 0,
    "limit": 0,
    "search_type": ""
  }
}

settings {
  encodeUrl: true
}

example {
  name: 200 CTrader Trade History
  
  request: {
    url: {{BASE_URL}}/private/v1/trade/trades/search
    method: POST
    mode: json
    body:json: {
      {
          "skip": 0,
          "limit": 10,
          "type": "trade history",
          "connection_id": "1ijlvhv6",
          "orders": {
              "volume": 1 // volume | open_price | close_price | close_time | stop_loss | take_profit | commission | swaps | trade_history_profit
          },
          "searches": [
              {
                  "field": "name",
                  "value": "user",
                  "opt": "EQ"
              },
              {
                  "field": "open_order_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "close_order_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "trading_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "trade_side",
                  "value": [
                      "1", // Buy
                      "2" // Sell
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "open_trade_side",
                  "value": [
                      "1", // Buy
                      "2" // Sell
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "type",
                  "value": [
                      "1", // MARKET
                      "4", // STOP_LOSS_TAKE_PROFIT
                      "6", // STOP_LIMIT
                      "2", // LIMIT
                      "5", // MARKET_RANGE
                      "3" // STOP
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "symbol",
                  "value": [
                      "USDTRY",
                      "EURTRY"
                  ],
                  "opt": "EQ"
              },
              {
                  "field": "volume",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "open_price",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "close_price",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "stop_loss",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "take_profit",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "trading_fee",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "swaps",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "profit",
                  "value": {
                      "start": 0,
                      "end": 1
                  },
                  "opt": "EQ"
              },
              {
                  "field": "user_id",
                  "value": "123",
                  "opt": "EQ"
              },
              {
                  "field": "referrer_id",
                  "value": {
                      "user_id": [
                          "lo0i7w3o"
                      ],
                      "type": "all", // "all"｜ "upline" ｜ "customer"
                      "max_depth": 1, // (only type === "customer")
                      "start_depth": 1 // 0 | 1 (only type === "customer")
                  },
                  "opt": "EQ"
              },
              {
                  "field": "reports_trade_history_tier",
                  "value": {
                      "rank_id": "rd3ktdmy",
                      "tiers": [1, 2, 3]
                  },
                  "opt": "EQ"
              }
          ],
          "range": [
              {
                  "field": "open_time",
                  "opt": "EQ",
                  "value": {
                      "start": "2026-01-01 00:00:00",
                      "end": "2026-01-28 23:59:59"
                  }
              },
              {
                  "field": "close_time",
                  "opt": "EQ",
                  "value": {
                      "start": "2026-01-21 00:00:00",
                      "end": "2026-01-28 23:59:59"
                  }
              }
          ],
          "last": false,
          "key": "" // Order ID
      }
    }
  }
  
  response: {
    status: {
      code: OK
      text: 200
    }
  
    body: {
      type: text
      content: '''
        {
            "trades": [
                {
                    "order_id": "12741",
                    "trading_id": 3000618,
                    "type": 4,
