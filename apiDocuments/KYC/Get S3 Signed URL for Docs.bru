meta {
  name: Get S3 Signed URL for Docs
  type: http
  seq: 11
}

post {
  url: {{BASE_URL}}/private/v1/file/s3/url
  body: json
  auth: inherit
}

body:json {
  {
    "urls": [
      {
        "name": "",
        "url": ""
      }
    ],
    "security": true
  }
}

settings {
  encodeUrl: true
}

example {
  name: OK
  
  request: {
    url: {{BASE_URL}}/private/v1/file/s3/url
    method: POST
    mode: json
    body:json: {
      {
        "urls": [
          {
            "name": "real_ID_card_back_side.png",
            "url": "apps/kyc/users/klp9koqa/forms/pwlt0q4e/alt_identity_doc_kn30"
          }
        ],
        "security": true
      }
    }
  }
  
