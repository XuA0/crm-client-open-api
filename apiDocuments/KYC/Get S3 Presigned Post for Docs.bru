meta {
  name: Get S3 Presigned Post for Docs
  type: http
  seq: 10
}

get {
  url: {{BASE_URL}}/private/v1/form/s3/signature?content_type=&document=&form_id=&id=
  body: none
  auth: bearer
}

params:query {
  content_type: 
  document: 
  form_id: 
  id: 
}

auth:bearer {
  token: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
}

example {
  name: OK
  
  request: {
    url: {{BASE_URL}}/private/v1/form/s3/signature?content_type=image/png&document=alt_identity_doc&form_id=gl18dz8t&id=6gu1
    method: GET
    mode: none
    params:query: {
      content_type: image/png
      document: alt_identity_doc
      form_id: gl18dz8t
      id: 6gu1
    }
  }
  
  response: {
    body: {
      type: text
      content: '''
        {
            "url": "https://crm-broctagon-development-private.s3.ap-southeast-1.amazonaws.com/",
            "fields": {
                "acl": "private",
                "key": "apps/kyc/users/lifupiht/forms/msuv0fdi/alt_identity_doc_77fm",
                "Content-Type": "image/png",
                "bucket": "crm-broctagon-development-private",
                "X-Amz-Algorithm": "AWS4-HMAC-SHA256",
                "X-Amz-Credential": "ASIATYHHSZ6VDTKV6URS/20251111/ap-southeast-1/s3/aws4_request",
                "X-Amz-Date": "20251111T070535Z",
                "X-Amz-Security-Token": "",
                "Policy": "",
                "X-Amz-Signature": "3e897e856273be47818e0e46a55c18089b7974b09ea2ddfb34e82568d62ec987"
            }
        }
      '''
    }
  }
}
