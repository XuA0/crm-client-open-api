meta {
  name: Get User MFA Secret
  type: http
  seq: 12
}

get {
  url: {{BASE_URL}}/private/v2/account/mfa
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

example {
  name: 200
  
  request: {
    url: {{BASE_URL}}/private/v2/account/mfa
    method: GET
    mode: json
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: OK
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
            "qr_code": "data:image/png;base64,",
            "secret": "ONFG4Y35JRAUU33DIRIXQ5LFIFKFUUZMOAXWE2KJKE3EI4BSMVQQ"
        }
      '''
    }
  }
}
