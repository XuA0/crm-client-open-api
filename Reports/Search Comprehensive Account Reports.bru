example {
  name: CTrader
  
  request: {
    url: {{BASE_URL}}/private/v1/statistics/reports/capital/search
    method: POST
    mode: json
    body:json: {
      {
          "skip": 0,
          "limit": 10,
          "mine":true,
          "connection_id": "1ijlvhv6",
          "searches": [
              {
