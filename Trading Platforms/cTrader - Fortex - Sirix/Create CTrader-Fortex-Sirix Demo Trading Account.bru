          "currency": "USD",
          "account_type_id": "k8ybt498",
          "group": "dev\\CRM\\QA_testing\\Demo-fortex"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
